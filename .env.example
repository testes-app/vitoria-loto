# Super Lotofácil - Environment Variables
# Copie para .env e preencha os valores

# Database
DATABASE_TYPE=sqlite
DATABASE_PATH=data/lotofacil.db

# PostgreSQL (se usar)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lotofacil
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_password_here

# API Keys (se necessário)
LOTOFACIL_API_KEY=

# Email (notificações)
EMAIL_SMTP_SERVER=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SENDER=seu@email.com
EMAIL_PASSWORD=sua_senha
EMAIL_RECIPIENTS=destinatario@email.com

# Telegram (notificações)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Configurações
LOG_LEVEL=INFO
CACHE_ENABLED=true
PARALLEL_WORKERS=8

# Web App
WEB_HOST=localhost
WEB_PORT=8501
